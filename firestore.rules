rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidSpotStatus() {
      return request.resource.data.status in
        ['available', 'soonAvailable', 'lowConfidence', 'taken'];
    }

    function isNotExpired() {
      return request.resource.data.expiresAt > request.time;
    }

    function spotLocationUnchanged() {
      return request.resource.data.lat == resource.data.lat
          && request.resource.data.lng == resource.data.lng;
    }

    function spotReporterUnchanged() {
      return request.resource.data.reportedBy == resource.data.reportedBy;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read public profiles (leaderboard)
      allow read: if isSignedIn();

      // Only the owner can create or update their own profile
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);

      // No deletes
      allow delete: if false;
    }

    // ── Parking Spots ─────────────────────────────────────────────────────────
    match /parking_spots/{spotId} {
      // PUBLIC read — demo mode and unauthenticated users can see spots on map
      allow read: if true;

      // Only authenticated users can create spots
      allow create: if isSignedIn()
        && isValidSpotStatus()
        && isNotExpired()
        && request.resource.data.reportedBy == request.auth.uid;

      // Authenticated users can update status/confidence/timer.
      // Location and reporter are immutable after creation.
      allow update: if isSignedIn()
        && spotLocationUnchanged()
        && spotReporterUnchanged();

      // Only the original reporter can delete their spot
      allow delete: if isSignedIn()
        && resource.data.reportedBy == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      // Authenticated users can read reports
      allow read: if isSignedIn();

      // Only the authenticated user can file a report under their own uid
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Reports are immutable audit trail
      allow update, delete: if false;
    }
  }
}
